{
  "name": "tagzeit-generator",
  "version": "1.0.0",
  "description": "Synthetic data generator for Project Tagzeit temporal reasoning",
  "main": "src/generator.js",
  "scripts": {
    "generate:pot":  "node src/generator.js --count 5000 --output data/train/train_pot.jsonl --eval data/eval/eval_pot.jsonl",
    "generate:poc":  "node src/generator.js --count 50000 --output data/train/train_poc.jsonl --eval data/eval/eval_poc.jsonl",
    "generate:prod": "node src/generator.js --count 250000 --output data/train/train_prod.jsonl --eval data/eval/eval_prod.jsonl"
  },
  "dependencies": {
    "@faker-js/faker": "8.4.1",
    "luxon": "3.4.4",
    "yargs": "17.7.2"
  }
}
